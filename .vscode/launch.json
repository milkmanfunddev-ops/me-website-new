{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev Server (Web)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@mealvana/web", "dev", "--port", "3001"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/packages/web/.env.local",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Convex Dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["convex", "dev"],
      "cwd": "${workspaceFolder}/packages/convex",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Sanity Studio",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@mealvana/sanity", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Web + Convex)",
      "configurations": ["Dev Server (Web)", "Convex Dev"]
    }
  ]
}
